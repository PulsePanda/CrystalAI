    },
    "core_template": {
      "description": "Files that seed personal configuration on first install. Merged on update if user has customized.",
      "classifications": ["scaffold"],
      "update_behavior": "merge_if_customized"
    },
    "personal": {
      "description": "User data and customizations. Never touched by updates.",
      "paths": "protected_paths",
      "update_behavior": "never_touch"
    },
    "vault": {
      "description": "Vault directory structure and templates. Create if missing, skip if exists with content.",
      "classifications": ["vault_structure"],
      "update_behavior": "create_if_missing"
    }
